{
  "name": "enclave-supervisor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Enclave supervisor — the whole service, running inside the Tinfoil enclave behind the shim. Control + data + per-use container launch. Nothing external touches a prompt.",
  "main": "supervisor.js",
  "scripts": {
    "start": "node supervisor.js",
    "dev": "node --watch supervisor.js",
    "test": "node --test --test-timeout=15000 test/*.test.mjs",
    "build:site": "node scripts/build-site.mjs",
    "watch:site": "tailwindcss -i site/css/src/main.css -o site/css/site.css --watch"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.1",
    "@noble/hashes": "^1.8.0",
    "@tinfoilsh/verifier": "^1.1.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "solc": "^0.8.35",
    "viem": "^2.53.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.3.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
