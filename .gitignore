node_modules/
.env
*.log
node_modules/
__pycache__/
*.pyc
# root tinfoil-config.yml exists only in release-tag commits (generated from
# enclaves/<flavor>/tinfoil-config.yml by the release workflows); never commit
# a stray local copy to main
/tinfoil-config.yml
# in-tree wasm app crates: build artifacts + cargo-component's generated bindings
wasm/apps/*/target/
wasm/apps/*/src/bindings.rs
wasm/apps/*/assets/
# but keep the small embedded config (source, not a fetched artifact)
!wasm/apps/*/assets/app-config.json
# enclave CLI: bundled single-file build (cli/install.sh or npm run build)
cli/dist/
# site: bundled output (built by scripts/build-site.mjs; deploy.sh ships it)
site/dist/
# privy bundle build workspace (scripts/build-privy.mjs; its output site/privy/ IS committed)
scripts/.privy-build/
# rolling archive of hashed site chunks (deploy.sh ships the union so cached
# entries keep resolving their chunks across deploys)
site/.chunk-archive/
