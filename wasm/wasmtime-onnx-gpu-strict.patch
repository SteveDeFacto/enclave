+/// Enclave: extract a session output as a wasi-nn tensor, faithful to the value's
+/// actual element type. The upstream code extracted every output as f32
+/// ("TODO: fix preexisting gap"), which fails outright on fp16/i64 outputs -
+/// i.e. on the logits and KV-cache tensors of any real transformer model.
+fn extract_output_tensor(value: &ort::value::Value) -> Result<Tensor, BackendError> {
+    let elem = match value.dtype() {
+        ValueType::Tensor { ty, .. } => *ty,
+        other => {
+            return Err(BackendError::BackendAccess(wasmtime::format_err!(
+                "unsupported ONNX output value type: {other:?}"
+            )));
+        }
+    };
+    macro_rules! extract {
+        ($elem:ty) => {{
+            let (shape, data): (&ort::tensor::Shape, &[$elem]) = value.try_extract_tensor()?;
+            let dimensions: Vec<u32> = (*shape)
+                .iter()
+                .map(|d| if *d == -1 { Ok(1) } else { convert_i64(d) })
+                .collect::<Result<_, BackendError>>()?;
+            let bytes: Vec<u8> = data.iter().flat_map(|v| v.to_le_bytes()).collect();
+            (dimensions, bytes)
+        }};
+    }
+    let (ty, (dimensions, data)) = match elem {
+        TensorElementType::Float32 => (TensorType::Fp32, extract!(f32)),
+        TensorElementType::Float64 => (TensorType::Fp64, extract!(f64)),
+        TensorElementType::Float16 => (TensorType::Fp16, extract!(f16)),
+        TensorElementType::Bfloat16 => (TensorType::Bf16, extract!(bf16)),
+        TensorElementType::Int32 => (TensorType::I32, extract!(i32)),
+        TensorElementType::Int64 => (TensorType::I64, extract!(i64)),
+        TensorElementType::Uint8 => (TensorType::U8, extract!(u8)),
+        other => {
+            return Err(BackendError::BackendAccess(wasmtime::format_err!(
+                "unsupported ONNX output tensor element type: {other:?}"
+            )));
+        }
+    };
+    Ok(Tensor {
+        dimensions,
+        ty,
+        data,
+    })
+}
+
 pub fn f32_vec_to_bytes(data: Vec<f32>) -> Vec<u8> {
     data.into_iter().flat_map(f32::to_le_bytes).collect()
 }
