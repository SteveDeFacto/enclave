--- /dev/null
+++ b/crates/wasi-nn/src/backend/ggml.rs
@@ -0,0 +1,345 @@
+//! A ggml/llama.cpp backend for wasi-nn — GGUF language models behind the
+//! standard `wasi:nn` interface.
+//!
+//! The heavy lifting happens in the system-linked `enclave_llama` shim (a
+//! flat pointer/scalar C ABI over llama.cpp, shipped next to libllama in the
+//! enclave-llamacpp toolchain artifact — see wasm/llama-shim in the platform
+//! repo). This file binds nine shim functions and adapts them to the
+//! wasi-nn backend traits. No new crates: std + FFI only, so the toolchain
+//! patch carries no Cargo.lock delta.
+//!
+//! The llama.cpp libs are built GGML_BACKEND_DL: the compute backends (cpu,
+//! cuda) are dlopened modules, loaded by `ell_init()` from
+//! ENCLAVE_GGML_BACKEND_DIR — the wasmtime binary carries no DT_NEEDED on
+//! libcuda.so.1, so it starts on driverless (CPU-flavor) nodes. The flip
+//! side is that a broken CUDA module load degrades SILENTLY to CPU, so
+//! `load_path` enforces: GPU offload requested but no ggml GPU device
+//! loaded = loud failure, never a silent CPU fallback (tenants BUY the
+//! share — same discipline as the strict-GPU ONNX patch).
+//!
+//! Model delivery is `load_by_name()` via the CLI preload registry
+//! (`-S nn-graph=ggml::<dir>`): the HOST opens the GGUF straight off the
+//! (read-only, attested) model volume, so weights never transit the guest's
+//! 32-bit linear memory — the whole point for large models. `load()` from
+//! guest bytes also works for small models: the bytes are staged to a temp
+//! file because llama.cpp wants a path.
+//!
+//! Inference contract (WIT named tensors):
+//!   input  "tokens"  I32  dims [1, n] (n <= n_batch)   token ids
+//!   output "logits"  Fp32 dims [1, n_vocab]            last-token logits
+//! The execution context owns a llama context; its KV cache persists across
+//! `compute()` calls, so a generate loop feeds the sampled token back one at
+//! a time. A fresh wasi-nn execution context = a fresh sequence.
+//!
+//! Tuning env (host process only, set per tenant by the wasm-manager):
+//!   ENCLAVE_GGML_N_CTX          context window (default 8192; 0 = model max)
+//!   ENCLAVE_GGML_N_BATCH        max tokens per compute (default 512)
+//!   ENCLAVE_GGML_N_GPU_LAYERS   -1 = offload all (default when built with
+//!                               CUDA-enabled libllama), 0 = pure CPU
+//!   ENCLAVE_GGML_BACKEND_DIR    dir holding the dlopened libggml-* backend
+//!                               modules (unset = exe dir + cwd)
+
+use super::{
+    BackendError, BackendExecutionContext, BackendFromDir, BackendGraph, BackendInner, Id,
+    NamedTensor,
+};
+use crate::wit::types::{ExecutionTarget, GraphEncoding, Tensor, TensorType};
+use crate::{ExecutionContext, Graph};
+use std::ffi::{c_char, c_void, CString};
+use std::path::Path;
+use std::sync::{Arc, Once};
+
+unsafe extern "C" {
+    fn ell_init();
+    fn ell_gpu_devices() -> i32;
+    fn ell_load_model(path: *const c_char, n_gpu_layers: i32) -> *mut c_void;
+    fn ell_free_model(model: *mut c_void);
+    fn ell_n_vocab(model: *mut c_void) -> i32;
+    fn ell_new_context(model: *mut c_void, n_ctx: u32, n_batch: u32) -> *mut c_void;
+    fn ell_free_context(ctx: *mut c_void);
+    #[allow(dead_code)]
+    fn ell_reset(ctx: *mut c_void);
+    fn ell_decode(
+        ctx: *mut c_void,
+        model: *mut c_void,
+        tokens: *const i32,
+        n: i32,
+        logits_out: *mut f32,
+    ) -> i32;
+}
+
+static INIT: Once = Once::new();
+
+fn err(msg: impl Into<String>) -> BackendError {
+    BackendError::BackendAccess(wasmtime::format_err!("{}", msg.into()))
+}
+
+fn env_u32(name: &str, default: u32) -> u32 {
+    std::env::var(name).ok().and_then(|v| v.parse().ok()).unwrap_or(default)
+}
+
+fn env_i32(name: &str, default: i32) -> i32 {
+    std::env::var(name).ok().and_then(|v| v.parse().ok()).unwrap_or(default)
+}
+
+#[derive(Default)]
+pub struct GgmlBackend();
+unsafe impl Send for GgmlBackend {}
+unsafe impl Sync for GgmlBackend {}
+
+impl GgmlBackend {
+    fn load_path(&self, path: &Path, target: ExecutionTarget) -> Result<Graph, BackendError> {
+        INIT.call_once(|| unsafe { ell_init() });
+        // GPU offload only when asked for AND the linked libllama carries a
+        // GPU backend; a CPU-only libllama silently ignores n_gpu_layers.
+        let ngl = match target {
+            ExecutionTarget::Cpu => 0,
+            _ => env_i32("ENCLAVE_GGML_N_GPU_LAYERS", -1),
+        };
+        // Strict GPU: the CUDA backend is a dlopened module whose load
+        // failure (missing libcuda, wrong SASS, future lib drift) is silent
+        // by design — a 122B model "working" at CPU speed is the failure
+        // mode, so offload-requested + no GPU device = refuse loudly.
+        if ngl != 0 && unsafe { ell_gpu_devices() } == 0 {
+            return Err(err(
+                "ggml: GPU offload requested (ENCLAVE_GGML_N_GPU_LAYERS != 0) but no ggml GPU \
+                 device is available — CUDA backend module or driver missing",
+            ));
+        }
+        let cpath = CString::new(path.to_string_lossy().as_bytes())
+            .map_err(|_| err("model path contains NUL"))?;
+        let model = unsafe { ell_load_model(cpath.as_ptr(), ngl) };
+        if model.is_null() {
+            return Err(err(format!("llama.cpp failed to load {}", path.display())));
+        }
+        let n_vocab = unsafe { ell_n_vocab(model) };
+        if n_vocab <= 0 {
+            unsafe { ell_free_model(model) };
+            return Err(err("model reports no vocabulary"));
+        }
+        let graph: Box<dyn BackendGraph> = Box::new(GgmlGraph(Arc::new(GgmlModel {
+            raw: model,
+            n_vocab: n_vocab as u32,
+        })));
+        Ok(graph.into())
+    }
+}
+
+impl BackendInner for GgmlBackend {
+    fn encoding(&self) -> GraphEncoding {
+        GraphEncoding::Ggml
+    }
+
+    fn load(&mut self, builders: &[&[u8]], target: ExecutionTarget) -> Result<Graph, BackendError> {
+        if builders.len() != 1 {
+            return Err(BackendError::InvalidNumberOfBuilders(1, builders.len()));
+        }
+        // llama.cpp opens files, not buffers: stage guest bytes to a temp
+        // GGUF. Only viable for small models (the bytes crossed the guest's
+        // 32-bit memory to get here); big models come via load_by_name.
+        let dir = std::env::temp_dir().join(format!("wasi-nn-ggml-{}", std::process::id()));
+        std::fs::create_dir_all(&dir).map_err(|e| err(format!("staging dir: {e}")))?;
+        let path = dir.join(format!("model-{:x}.gguf", builders[0].len()));
+        std::fs::write(&path, builders[0]).map_err(|e| err(format!("staging model: {e}")))?;
+        let graph = self.load_path(&path, target);
+        // the shim mmaps/reads it during load; safe to unlink either way
+        let _ = std::fs::remove_file(&path);
+        graph
+    }
+
+    fn as_dir_loadable<'a>(&'a mut self) -> Option<&'a mut dyn BackendFromDir> {
+        Some(self)
+    }
+}
+
+impl BackendFromDir for GgmlBackend {
+    fn load_from_dir(&mut self, path: &Path, target: ExecutionTarget) -> Result<Graph, BackendError> {
+        // model.gguf wins; otherwise exactly one *.gguf in the directory.
+        let preferred = path.join("model.gguf");
+        let model_path = if preferred.is_file() {
+            preferred
+        } else {
+            let mut ggufs: Vec<_> = std::fs::read_dir(path)
+                .map_err(|e| err(format!("reading {}: {e}", path.display())))?
+                .filter_map(|e| e.ok().map(|e| e.path()))
+                .filter(|p| p.extension().map(|x| x == "gguf").unwrap_or(false))
+                .collect();
+            match (ggufs.len(), ggufs.pop()) {
+                (1, Some(p)) => p,
+                (n, _) => {
+                    return Err(err(format!(
+                        "expected model.gguf or exactly one *.gguf in {} (found {n})",
+                        path.display()
+                    )))
+                }
+            }
+        };
+        // Preloads arrive with ExecutionTarget::Cpu from the registry; the
+        // env override decides real offload so operators control it per
+        // process without patching the registry call.
+        let ngl_env = env_i32("ENCLAVE_GGML_N_GPU_LAYERS", i32::MIN);
+        let target = if ngl_env != i32::MIN && ngl_env != 0 {
+            ExecutionTarget::Gpu
+        } else {
+            target
+        };
+        self.load_path(&model_path, target)
+    }
+}
+
+struct GgmlModel {
+    raw: *mut c_void,
+    n_vocab: u32,
+}
+unsafe impl Send for GgmlModel {}
+unsafe impl Sync for GgmlModel {}
+impl Drop for GgmlModel {
+    fn drop(&mut self) {
+        unsafe { ell_free_model(self.raw) };
+    }
+}
+
+struct GgmlGraph(Arc<GgmlModel>);
+unsafe impl Send for GgmlGraph {}
+unsafe impl Sync for GgmlGraph {}
+
+impl BackendGraph for GgmlGraph {
+    fn init_execution_context(&self) -> Result<ExecutionContext, BackendError> {
+        let n_ctx = env_u32("ENCLAVE_GGML_N_CTX", 8192);
+        let n_batch = env_u32("ENCLAVE_GGML_N_BATCH", 512);
+        let raw = unsafe { ell_new_context(self.0.raw, n_ctx, n_batch) };
+        if raw.is_null() {
+            return Err(err("llama.cpp context allocation failed (n_ctx too large for the share?)"));
+        }
+        let ctx: Box<dyn BackendExecutionContext> = Box::new(GgmlExecutionContext {
+            model: self.0.clone(),
+            raw,
+            n_batch,
+            pending: None,
+            logits: None,
+        });
+        Ok(ctx.into())
+    }
+}
+
+struct GgmlExecutionContext {
+    model: Arc<GgmlModel>,
+    raw: *mut c_void,
+    n_batch: u32,
+    pending: Option<Vec<i32>>,  // WITX-style set_input staging
+    logits: Option<Tensor>,     // last compute's output for get_output
+}
+unsafe impl Send for GgmlExecutionContext {}
+unsafe impl Sync for GgmlExecutionContext {}
+impl Drop for GgmlExecutionContext {
+    fn drop(&mut self) {
+        unsafe { ell_free_context(self.raw) };
+    }
+}
+
+fn tokens_from_tensor(tensor: &Tensor) -> Result<Vec<i32>, BackendError> {
+    match tensor.ty {
+        TensorType::I32 => {}
+        _ => return Err(BackendError::UnsupportedTensorType(format!("{:?}", tensor.ty))),
+    }
+    if tensor.data.len() % 4 != 0 {
+        return Err(err("token tensor data is not a whole number of i32s"));
+    }
+    Ok(tensor
+        .data
+        .chunks_exact(4)
+        .map(|b| i32::from_le_bytes([b[0], b[1], b[2], b[3]]))
+        .collect())
+}
+
+impl GgmlExecutionContext {
+    fn decode(&mut self, tokens: &[i32]) -> Result<Tensor, BackendError> {
+        if tokens.is_empty() {
+            return Err(err("empty token batch"));
+        }
+        if tokens.len() > self.n_batch as usize {
+            return Err(err(format!(
+                "batch of {} tokens exceeds n_batch {} (chunk your prefill)",
+                tokens.len(),
+                self.n_batch
+            )));
+        }
+        let n_vocab = self.model.n_vocab as usize;
+        let mut logits = vec![0f32; n_vocab];
+        let rc = unsafe {
+            ell_decode(
+                self.raw,
+                self.model.raw,
+                tokens.as_ptr(),
+                tokens.len() as i32,
+                logits.as_mut_ptr(),
+            )
+        };
+        if rc != 0 {
+            return Err(err(format!("llama_decode failed (rc {rc}; context window exhausted?)")));
+        }
+        let mut data = Vec::with_capacity(n_vocab * 4);
+        for v in logits {
+            data.extend_from_slice(&v.to_le_bytes());
+        }
+        Ok(Tensor {
+            dimensions: vec![1, self.model.n_vocab],
+            ty: TensorType::Fp32,
+            data,
+        })
+    }
+}
+
+impl BackendExecutionContext for GgmlExecutionContext {
+    fn set_input(&mut self, id: Id, tensor: &Tensor) -> Result<(), BackendError> {
+        match id {
+            Id::Index(0) => {}
+            Id::Name(ref n) if n == "tokens" => {}
+            other => return Err(err(format!("unknown input {other:?} (expected \"tokens\")"))),
+        }
+        self.pending = Some(tokens_from_tensor(tensor)?);
+        Ok(())
+    }
+
+    fn compute(
+        &mut self,
+        inputs: Option<Vec<NamedTensor>>,
+    ) -> Result<Option<Vec<NamedTensor>>, BackendError> {
+        match inputs {
+            // WIT path: named tensors in, named tensors out
+            Some(inputs) => {
+                let tokens = inputs
+                    .iter()
+                    .find(|nt| nt.name == "tokens" || nt.name == "0")
+                    .ok_or_else(|| err("missing \"tokens\" input"))?;
+                let ids = tokens_from_tensor(&tokens.tensor)?;
+                let logits = self.decode(&ids)?;
+                self.logits = Some(logits.clone());
+                Ok(Some(vec![NamedTensor {
+                    name: "logits".to_string(),
+                    tensor: logits,
+                }]))
+            }
+            // WITX path: tokens staged via set_input, result via get_output
+            None => {
+                let ids = self
+                    .pending
+                    .take()
+                    .ok_or_else(|| err("no input staged (call set_input first)"))?;
+                self.logits = Some(self.decode(&ids)?);
+                Ok(None)
+            }
+        }
+    }
+
+    fn get_output(&mut self, id: Id) -> Result<Tensor, BackendError> {
+        match id {
+            Id::Index(0) => {}
+            Id::Name(ref n) if n == "logits" => {}
+            other => return Err(err(format!("unknown output {other:?} (expected \"logits\")"))),
+        }
+        self.logits
+            .clone()
+            .ok_or_else(|| err("no logits available (has `compute` been called?)"))
+    }
+}
