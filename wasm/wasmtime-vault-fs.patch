+    /// Preopen a nan-vault NANVOL2 encrypted directory (read-only, decrypted
+    /// on demand; see `crate::vault`).
+    ///
+    /// `host_path` is the SKELETON: a real directory tree whose files are
+    /// sparse placeholders truncated to the plaintext sizes — it serves every
+    /// metadata operation (stat, readdir, open, inode identity). `cipher_dir`
+    /// is the NANVOL2 cipherdir holding the encrypted blobs + manifest, and
+    /// `vek` is the 32-byte volume encryption key that unseals the manifest
+    /// and derives the per-file block keys. Content reads decrypt only the
+    /// touched blocks, through a small bounded cache; the preopen is forced
+    /// read-only, so guests can never write through the skeleton.
+    pub fn preopened_vault_dir(
+        &mut self,
+        host_path: impl AsRef<Path>,
+        guest_path: impl AsRef<str>,
+        cipher_dir: impl AsRef<Path>,
+        vek: [u8; 32],
+    ) -> Result<&mut Self> {
+        let vol = crate::vault::VaultVol::open(cipher_dir.as_ref(), &vek)?;
+        let dir = cap_std::fs::Dir::open_ambient_dir(host_path.as_ref(), ambient_authority())?;
+        let mut dir = Dir::new(
+            dir,
+            DirPerms::READ,
+            FilePerms::READ,
+            OpenMode::READ,
+            self.filesystem.allow_blocking_current_thread,
+        );
+        dir.vault = Some(crate::vault::VaultDirCtx::new(vol));
+        self.filesystem
+            .preopens
+            .push((dir, guest_path.as_ref().to_owned()));
+        Ok(self)
+    }
+
     /// Set the generator for the `wasi:random/random` number generator to the
     /// custom generator specified.
     ///
