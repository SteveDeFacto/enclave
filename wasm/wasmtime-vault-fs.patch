diff --git a/crates/wasi/src/vault.rs b/crates/wasi/src/vault.rs
new file mode 100644
index 0000000..cbc0aa6
--- /dev/null
+++ b/crates/wasi/src/vault.rs
@@ -0,0 +1,388 @@
+//! nan-vault NANVOL2: transparent, read-only, on-demand decryption for
+//! preopened directories — gocryptfs semantics with ZERO privileges.
+//!
+//! A NANVOL2 "cipherdir" (produced by nan's `nan-vault pack-blocks`) holds one
+//! encrypted blob per plaintext file, split into fixed-size XChaCha20-Poly1305
+//! blocks, plus a VEK-sealed JSON manifest mapping logical paths to blobs and
+//! sizes. The host preopens a SKELETON directory (a real tree of sparse files
+//! truncated to the plaintext sizes, so every metadata operation — stat,
+//! readdir, open, inode identity — is served by the kernel on real objects)
+//! and this module intercepts only CONTENT READS: each `read_at` decrypts the
+//! touched 4MiB blocks from the cipherdir, verifies their AEAD tags, and
+//! serves the requested byte range through a small bounded LRU. Plaintext
+//! never exists outside that cache; writes are impossible (the preopen is
+//! forced read-only and blobs live on a read-only volume).
+//!
+//! Crypto (must match nan's scripts/nan-vault.mjs, the protocol's source of
+//! truth): fileKey = HKDF-SHA256(VEK, salt=packId, info="nan-vault/file/v1:"
+//! + blobName); block nonce = LE64(blockIndex) || 16 zero bytes; each stored
+//! block is ciphertext||tag at offset blockIndex * (blockSize + 16). The
+//! manifest file is a NANVOL1 blob: "NANVOL1" || nonce(24) || XChaCha20-
+//! Poly1305(json). Keys are unique per (pack, blob), so blocks cannot be
+//! swapped across files, reordered within a file, or transplanted from
+//! another pack; truncation/extension is caught against the manifest size.
+
+use bytes::Bytes;
+use chacha20poly1305::aead::{Aead, KeyInit};
+use chacha20poly1305::{Key, XChaCha20Poly1305, XNonce};
+use hkdf::Hkdf;
+use sha2::Sha256;
+use std::collections::HashMap;
+use std::io::{Error, ErrorKind, Result};
+use std::path::Path;
+use std::sync::{Arc, Mutex};
+
+const NANVOL1_MAGIC: &[u8] = b"NANVOL1";
+const TAG_LEN: u64 = 16;
+const DEFAULT_CACHE_MB: usize = 64;
+
+/// One unlocked NANVOL2 volume: the (sandboxed) cipherdir handle, the
+/// decrypted manifest, per-file keys, and the plaintext block cache.
+pub struct VaultVol {
+    cipher: cap_std::fs::Dir,
+    block_size: u64,
+    files: HashMap<String, VaultEntry>,
+    cache: Mutex<BlockCache>,
+}
+
+#[derive(Clone)]
+struct VaultEntry {
+    blob: String,
+    size: u64,
+    key: [u8; 32],
+}
+
+/// A vault-backed open file: routes `read_at` through block decryption.
+pub struct VaultFile {
+    vol: Arc<VaultVol>,
+    entry: VaultEntry,
+}
+
+/// Attached to a `Dir` descriptor inside a vault preopen: remembers the
+/// volume and this directory's logical path prefix so `open_at` can map
+/// opened files back to manifest entries.
+#[derive(Clone)]
+pub struct VaultDirCtx {
+    vol: Arc<VaultVol>,
+    prefix: String,
+}
+
+struct BlockCache {
+    budget: usize,
+    used: usize,
+    seq: u64,
+    map: HashMap<(String, u64), (Bytes, u64)>,
+}
+
+fn bad(msg: impl Into<String>) -> Error {
+    Error::new(ErrorKind::InvalidData, format!("nan-vault: {}", msg.into()))
+}
+
+fn unhex(s: &str) -> Option<Vec<u8>> {
+    let s = s.trim().trim_start_matches("0x");
+    if s.len() % 2 != 0 {
+        return None;
+    }
+    (0..s.len() / 2)
+        .map(|i| u8::from_str_radix(&s[2 * i..2 * i + 2], 16).ok())
+        .collect()
+}
+
+/// Lexically join + normalize a logical path under a prefix ("." and ".."
+/// resolved; the skeleton contains no symlinks, so lexical is exact).
+pub(crate) fn join_logical(prefix: &str, path: &str) -> String {
+    let mut parts: Vec<&str> = if prefix.is_empty() {
+        Vec::new()
+    } else {
+        prefix.split('/').collect()
+    };
+    for c in path.split('/') {
+        match c {
+            "" | "." => {}
+            ".." => {
+                parts.pop();
+            }
+            c => parts.push(c),
+        }
+    }
+    parts.join("/")
+}
+
+/// Open a NANVOL1 blob (magic || nonce24 || xchacha20poly1305(ct||tag)).
+fn open_nanvol1(blob: &[u8], key: &[u8; 32]) -> Result<Vec<u8>> {
+    let hdr = NANVOL1_MAGIC.len() + 24;
+    if blob.len() < hdr + TAG_LEN as usize || &blob[..NANVOL1_MAGIC.len()] != NANVOL1_MAGIC {
+        return Err(bad("not a nan-vault blob (bad header)"));
+    }
+    let nonce = XNonce::from_slice(&blob[NANVOL1_MAGIC.len()..hdr]);
+    XChaCha20Poly1305::new(Key::from_slice(key))
+        .decrypt(nonce, &blob[hdr..])
+        .map_err(|_| bad("manifest decrypt failed (wrong key or corrupt cipherdir)"))
+}
+
+impl VaultVol {
+    /// Open a cipherdir with the volume's VEK: decrypt + parse the manifest
+    /// and derive the per-file keys. ~KBs of work regardless of volume size.
+    pub fn open(cipher_dir: &Path, vek: &[u8; 32]) -> Result<Arc<Self>> {
+        let cipher =
+            cap_std::fs::Dir::open_ambient_dir(cipher_dir, cap_std::ambient_authority())?;
+        let sealed = cipher.read("manifest.nvm")?;
+        let plain = open_nanvol1(&sealed, vek)?;
+        let man: serde_json::Value =
+            serde_json::from_slice(&plain).map_err(|e| bad(format!("manifest json: {e}")))?;
+        if man.get("version").and_then(|v| v.as_u64()) != Some(1) {
+            return Err(bad("unsupported manifest version"));
+        }
+        let block_size = man
+            .get("blockSize")
+            .and_then(|v| v.as_u64())
+            .filter(|&b| b > 0)
+            .ok_or_else(|| bad("manifest blockSize"))?;
+        let pack_id = man
+            .get("packId")
+            .and_then(|v| v.as_str())
+            .and_then(unhex)
+            .ok_or_else(|| bad("manifest packId"))?;
+        let mut files = HashMap::new();
+        for f in man
+            .get("files")
+            .and_then(|v| v.as_array())
+            .ok_or_else(|| bad("manifest files"))?
+        {
+            let p = f.get("p").and_then(|v| v.as_str()).ok_or_else(|| bad("file path"))?;
+            let s = f.get("s").and_then(|v| v.as_u64()).ok_or_else(|| bad("file size"))?;
+            let b = f.get("b").and_then(|v| v.as_str()).ok_or_else(|| bad("file blob"))?;
+            let mut key = [0u8; 32];
+            Hkdf::<Sha256>::new(Some(&pack_id), vek)
+                .expand(format!("nan-vault/file/v1:{b}").as_bytes(), &mut key)
+                .map_err(|_| bad("hkdf"))?;
+            files.insert(
+                join_logical("", p),
+                VaultEntry { blob: b.to_string(), size: s, key },
+            );
+        }
+        let budget = std::env::var("NAN_VAULT_CACHE_MB")
+            .ok()
+            .and_then(|v| v.parse::<usize>().ok())
+            .unwrap_or(DEFAULT_CACHE_MB)
+            .saturating_mul(1024 * 1024);
+        Ok(Arc::new(Self {
+            cipher,
+            block_size,
+            files,
+            cache: Mutex::new(BlockCache { budget, used: 0, seq: 0, map: HashMap::new() }),
+        }))
+    }
+
+    /// The vault file at a logical path, if the manifest has one.
+    pub fn file(self: &Arc<Self>, logical: &str) -> Option<VaultFile> {
+        self.files
+            .get(logical)
+            .map(|entry| VaultFile { vol: self.clone(), entry: entry.clone() })
+    }
+
+    /// Fetch (cache or decrypt) one plaintext block of a file. The AEAD tag
+    /// is verified before any byte is returned.
+    fn block(&self, entry: &VaultEntry, idx: u64) -> Result<Bytes> {
+        let cache_key = (entry.blob.clone(), idx);
+        {
+            let mut c = self.cache.lock().unwrap();
+            c.seq += 1;
+            let seq = c.seq;
+            if let Some((b, last)) = c.map.get_mut(&cache_key) {
+                *last = seq;
+                return Ok(b.clone());
+            }
+        }
+        let plain_len = entry.size.saturating_sub(idx * self.block_size).min(self.block_size);
+        if plain_len == 0 {
+            return Err(bad("read past end of file"));
+        }
+        let want = (plain_len + TAG_LEN) as usize;
+        let mut sealed = vec![0u8; want];
+        let f = self.cipher.open(&entry.blob)?;
+        let mut got = 0;
+        while got < want {
+            let n = crate::filesystem::sys::read_at_cursor_unspecified(
+                &f,
+                &mut sealed[got..],
+                idx * (self.block_size + TAG_LEN) + got as u64,
+            )?;
+            if n == 0 {
+                return Err(bad(format!("blob {} truncated at block {idx}", entry.blob)));
+            }
+            got += n;
+        }
+        let mut nonce = [0u8; 24];
+        nonce[..8].copy_from_slice(&idx.to_le_bytes());
+        let plain = XChaCha20Poly1305::new(Key::from_slice(&entry.key))
+            .decrypt(XNonce::from_slice(&nonce), &sealed[..])
+            .map_err(|_| bad(format!("block {idx} of {} failed authentication", entry.blob)))?;
+        let plain = Bytes::from(plain);
+        let mut c = self.cache.lock().unwrap();
+        c.seq += 1;
+        let seq = c.seq;
+        if c.map.insert(cache_key, (plain.clone(), seq)).is_none() {
+            c.used += plain.len();
+        }
+        while c.used > c.budget && c.map.len() > 1 {
+            // tiny map (budget/blockSize entries): linear LRU scan is fine
+            let oldest = c
+                .map
+                .iter()
+                .min_by_key(|(_, (_, last))| *last)
+                .map(|(k, _)| k.clone());
+            match oldest {
+                Some(k) => {
+                    if let Some((b, _)) = c.map.remove(&k) {
+                        c.used -= b.len();
+                    }
+                }
+                None => break,
+            }
+        }
+        Ok(plain)
+    }
+}
+
+impl VaultFile {
+    /// Positional read, `pread(2)` semantics: fills `buf` from `offset`,
+    /// returns bytes read (0 at EOF). Decrypts only the touched blocks.
+    pub fn read_at(&self, buf: &mut [u8], offset: u64) -> Result<usize> {
+        let size = self.entry.size;
+        if offset >= size || buf.is_empty() {
+            return Ok(0);
+        }
+        let end = (offset + buf.len() as u64).min(size);
+        let bs = self.vol.block_size;
+        let mut written = 0usize;
+        for idx in offset / bs..=(end - 1) / bs {
+            let block = self.vol.block(&self.entry, idx)?;
+            let blk_start = idx * bs;
+            let lo = offset.max(blk_start) - blk_start;
+            let hi = end.min(blk_start + block.len() as u64).saturating_sub(blk_start);
+            if hi > block.len() as u64 || lo >= hi {
+                return Err(bad(format!("block {idx} shorter than manifest size")));
+            }
+            buf[written..written + (hi - lo) as usize]
+                .copy_from_slice(&block[lo as usize..hi as usize]);
+            written += (hi - lo) as usize;
+        }
+        Ok(written)
+    }
+}
+
+impl VaultDirCtx {
+    pub(crate) fn new(vol: Arc<VaultVol>) -> Self {
+        Self { vol, prefix: String::new() }
+    }
+
+    /// The context for a subdirectory opened at `path` under this one.
+    pub(crate) fn child(&self, path: &str) -> Self {
+        Self { vol: self.vol.clone(), prefix: join_logical(&self.prefix, path) }
+    }
+
+    /// The vault file for `path` opened under this directory, if any.
+    pub(crate) fn file(&self, path: &str) -> Option<VaultFile> {
+        self.vol.file(&join_logical(&self.prefix, path))
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    // A self-contained mini cipherdir: two files (one spanning blocks, one
+    // empty-tailed), sealed exactly like nan-vault.mjs packBlocks does.
+    fn make_cipherdir(dir: &Path, vek: &[u8; 32], block_size: u64) -> Vec<(String, Vec<u8>)> {
+        let pack_id: Vec<u8> = (0..16u8).collect();
+        let mut files = Vec::new();
+        let mut manifest_files = Vec::new();
+        std::fs::create_dir_all(dir.join("b")).unwrap();
+        for (i, (p, len)) in [("a.bin", block_size as usize * 2 + 7), ("sub/b.bin", 5)]
+            .iter()
+            .enumerate()
+        {
+            let blob = format!("b/{:06}.nvb", i + 1);
+            let data: Vec<u8> = (0..*len).map(|j| (j % 251) as u8).collect();
+            let mut key = [0u8; 32];
+            Hkdf::<Sha256>::new(Some(&pack_id), vek)
+                .expand(format!("nan-vault/file/v1:{blob}").as_bytes(), &mut key)
+                .unwrap();
+            let mut out = Vec::new();
+            for (idx, chunk) in data.chunks(block_size as usize).enumerate() {
+                let mut nonce = [0u8; 24];
+                nonce[..8].copy_from_slice(&(idx as u64).to_le_bytes());
+                out.extend(
+                    XChaCha20Poly1305::new(Key::from_slice(&key))
+                        .encrypt(XNonce::from_slice(&nonce), chunk)
+                        .unwrap(),
+                );
+            }
+            std::fs::write(dir.join(&blob), out).unwrap();
+            manifest_files.push(serde_json::json!({"p": p, "s": len, "b": blob}));
+            files.push((p.to_string(), data));
+        }
+        let manifest = serde_json::json!({
+            "version": 1, "blockSize": block_size,
+            "packId": pack_id.iter().map(|b| format!("{b:02x}")).collect::<String>(),
+            "files": manifest_files,
+        })
+        .to_string();
+        let mut nonce = [0u8; 24];
+        nonce[..8].copy_from_slice(b"manifest");
+        let mut sealed = NANVOL1_MAGIC.to_vec();
+        sealed.extend(&nonce);
+        sealed.extend(
+            XChaCha20Poly1305::new(Key::from_slice(vek))
+                .encrypt(XNonce::from_slice(&nonce), manifest.as_bytes())
+                .unwrap(),
+        );
+        std::fs::write(dir.join("manifest.nvm"), sealed).unwrap();
+        files
+    }
+
+    #[test]
+    fn reads_match_plaintext() {
+        let tmp = tempfile::tempdir().unwrap();
+        let vek = [7u8; 32];
+        let bs = 1024u64;
+        let files = make_cipherdir(tmp.path(), &vek, bs);
+        let vol = VaultVol::open(tmp.path(), &vek).unwrap();
+        for (p, data) in &files {
+            let vf = vol.file(p).expect("manifest entry");
+            // whole file
+            let mut buf = vec![0u8; data.len() + 3];
+            let n = vf.read_at(&mut buf, 0).unwrap();
+            assert_eq!(&buf[..n], &data[..]);
+            // cross-block ranges + EOF behavior
+            for (off, len) in [(0usize, 1usize), (1023, 2), (1024, 1024), (data.len() - 1, 5)] {
+                if *p != "a.bin" && off + len > data.len() {
+                    continue;
+                }
+                let mut buf = vec![0u8; len];
+                let n = vf.read_at(&mut buf, *&(off as u64)).unwrap();
+                assert_eq!(&buf[..n], &data[off..(off + len).min(data.len())]);
+            }
+            assert_eq!(vf.read_at(&mut [0u8; 8], data.len() as u64).unwrap(), 0);
+        }
+        // wrong VEK: manifest refuses
+        assert!(VaultVol::open(tmp.path(), &[8u8; 32]).is_err());
+        // tampered block: read refuses
+        let blob = tmp.path().join("b/000001.nvb");
+        let mut raw = std::fs::read(&blob).unwrap();
+        raw[10] ^= 0xff;
+        std::fs::write(&blob, raw).unwrap();
+        let vol = VaultVol::open(tmp.path(), &vek).unwrap();
+        let vf = vol.file("a.bin").unwrap();
+        assert!(vf.read_at(&mut [0u8; 16], 0).is_err());
+    }
+
+    #[test]
+    fn logical_paths() {
+        assert_eq!(join_logical("", "a/b"), "a/b");
+        assert_eq!(join_logical("a", "./b"), "a/b");
+        assert_eq!(join_logical("a/b", "../c"), "a/c");
+        assert_eq!(join_logical("", "../../x"), "x");
+    }
+}
