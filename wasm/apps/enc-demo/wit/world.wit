// enc-demo: the first-party sample for encrypted volumes (enclave-vault).
// Pure wasi:http; reads the decrypted volumes the platform preopens at
// /enc/<name> with plain WASI file I/O (std::fs) - the same code path for
// the small (NANVOL1, RAM) tier and the large (NANVOL2) tier under the
// wasmtime vault-fs shim. WIT deps vendored verbatim from wasmtime v45.
package enclave:enc-demo;

world enc-demo {
  export wasi:http/incoming-handler@0.2.6;
}
