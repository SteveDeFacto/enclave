#!/usr/bin/env bash
# pre-push: when commits that touch site/ are pushed to the deploy branch, deploy
# the site to IPFS via site/deploy.sh. Non-blocking: a deploy failure warns but
# does NOT abort your push (set NAN_DEPLOY_STRICT=1 to abort instead).
#
# Install once per clone (git does not auto-install hooks):
#     git config core.hooksPath scripts/hooks
# or symlink just this one:
#     ln -sf ../../scripts/hooks/pre-push .git/hooks/pre-push
set -uo pipefail
DEPLOY_BRANCH="${NAN_DEPLOY_BRANCH:-main}"     # repo default is 'main' (use 'master' if renamed)
REPO_ROOT="$(git rev-parse --show-toplevel)"
ZERO="0000000000000000000000000000000000000000"

changed=0
while read -r _localref localsha remoteref remotesha; do
  [ "$remoteref" = "refs/heads/$DEPLOY_BRANCH" ] || continue
  [ "$localsha" = "$ZERO" ] && continue                       # branch deletion: skip
  if [ "$remotesha" = "$ZERO" ]; then range="$localsha"; else range="$remotesha..$localsha"; fi
  if git diff --name-only "$range" -- site/ 2>/dev/null | grep -q .; then changed=1; fi
done

[ "$changed" = "1" ] || exit 0

echo "[pre-push] site/ changed on $DEPLOY_BRANCH -> deploying to IPFS"
if bash "$REPO_ROOT/site/deploy.sh"; then
  echo "[pre-push] site deployed"
  exit 0
fi
echo "[pre-push] WARNING: site deploy failed. Re-run manually: bash site/deploy.sh" >&2
[ "${NAN_DEPLOY_STRICT:-0}" = "1" ] && { echo "[pre-push] NAN_DEPLOY_STRICT=1 -> aborting push"; exit 1; }
exit 0
